# 🦔 什錦雜貨鋪 ETF - 環境變數設定
#
# ✨ 好消息：本專案使用 Yahoo Finance 免費 API
# 完全不需要任何 API Key 即可運行！
#
# 📋 使用方式：
#   1. 複製這個檔案為 .env.local（開發用）
#   2. 在 Zeabur 等平台設定環境變數（生產用）

# ============================================
# 環境設定
# ============================================

# 環境標識（development / production）
NEXT_PUBLIC_ENV=development

# 網站 URL
# - 開發環境：http://localhost:3000
# - 生產環境：https://your-domain.zeabur.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 是否開啟 Debug 模式（true/false）
# 開啟後會在 console 顯示更多資訊
NEXT_PUBLIC_DEBUG=false

# ============================================
# Upstash Redis（伺服器端快取）
# ============================================
# 用於多人訪問時的資料快取，避免頻繁呼叫外部 API
# 如果不設定，系統會優雅降級到直接抓取模式
#
# 取得方式（二選一）：
# A. Vercel 整合（推薦）：vercel integration add upstash/upstash-kv
#    → 自動注入 KV_REST_API_URL / KV_REST_API_TOKEN
# B. 手動：前往 https://upstash.com 註冊，複製 REST URL 和 Token

KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============================================
# Cron Job 安全設定（可選）
# ============================================
# 用於保護 Cron API 不被外部呼叫
# 如果不設定，會使用 Vercel 內建的驗證機制

CRON_SECRET=
